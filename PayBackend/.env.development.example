# Development Environment Configuration
# For local development and testing

# ===========================================
# Pay Plugin Required Variables (CANONICAL)
# ===========================================
PAY_DB_PASSWORD=123456
PAY_REDIS_PASSWORD=123456
PAY_API_KEY=test_key_123456

# ===========================================
# Application Configuration
# ===========================================
APP_THREADS=4
APP_ENABLE_SESSION=true
APP_SESSION_TIMEOUT=1200
APP_LOG_LEVEL=debug

# ===========================================
# Server Configuration
# ===========================================
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
SERVER_ENABLE_HTTPS=false

# ===========================================
# WeChat Pay Configuration (Sandbox)
# ===========================================
WECHAT_APPID=wx_sandbox_appid
WECHAT_MCHID=1234567890
WECHAT_API_V3_KEY=sandbox_api_key
WECHAT_CERT_PATH=./certs/sandbox/apiclient_cert.pem
WECHAT_KEY_PATH=./certs/sandbox/apiclient_key.pem
WECHAT_SERIAL_NO=sandbox_serial_no
WECHAT_NOTIFY_URL=http://localhost:8080/api/callback
WECHAT_BASE_URL=https://api.mch.weixin.qq.com/sandbox

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pay_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_CONNECTION_TIMEOUT=10
DB_MAX_CONNECTIONS=20

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=1
REDIS_PASSWORD=
REDIS_CONNECTION_TIMEOUT=5
REDIS_MAX_CONNECTIONS=10

# ===========================================
# Idempotency Configuration
# ===========================================
IDEMPOTENCY_TTL=86400
IDEMPOTENCY_USE_REDIS=true

# ===========================================
# Monitoring Configuration
# ===========================================
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=true

# ===========================================
# Security Configuration (Relaxed for dev)
# ===========================================
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# ===========================================
# Feature Flags
# ===========================================
ENABLE_REFUND=true
ENABLE_RECONCILIATION=true
ENABLE_CALLBACK=true
RECONCILIATION_CRON="0 2 * * *"

# ===========================================
# Development Settings
# ===========================================
ENABLE_HOT_RELOAD=false
VERBOSE_LOGGING=true
MOCK_WECHAT_PAY=false
