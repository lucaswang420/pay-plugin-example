# Pay Plugin Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ==============================================
# 支付宝沙箱配置 (Alipay Sandbox Configuration)
# ==============================================
# 获取步骤：
# 1. 访问 https://open.alipay.com/ 注册账号
# 2. 进入"研发服务" → "沙箱环境"
# 3. 获取沙箱 AppID 和密钥
# 4. 下载密钥生成器生成 RSA2 密钥对
# 5. 上传公钥到沙箱，下载支付宝公钥
ALIPAY_SANDBOX_APP_ID=YOUR_ALIPAY_SANDBOX_APP_ID
ALIPAY_SANDBOX_SELLER_ID=YOUR_ALIPAY_SANDBOX_SELLER_ID
ALIPAY_SANDBOX_PRIVATE_KEY_PATH=./certs/alipay_app_private_key.pem
ALIPAY_SANDBOX_PUBLIC_KEY_PATH=./certs/alipay_public_key.pem
ALIPAY_SANDBOX_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ==============================================
# 微信支付配置 (WeChat Pay Configuration)
# ==============================================
# 需要企业资质才能申请微信支付商户号
# WeChat Pay requires business license to apply

WECHAT_PAY_APP_ID=YOUR_WECHAT_APP_ID
WECHAT_PAY_MCH_ID=YOUR_MCH_ID
WECHAT_PAY_SERIAL_NO=YOUR_CERT_SERIAL_NO
WECHAT_PAY_API_V3_KEY=YOUR_API_V3_KEY
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PAY_PLATFORM_CERT_PATH=./certs/wechatpay_platform.pem
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/pay/notify/wechat

# ==============================================
# Pay Plugin Required Variables
# ==============================================
# Database password (REQUIRED)
PAY_DB_PASSWORD=YOUR_DB_PASSWORD

# Redis password (REQUIRED, empty string if no auth)
PAY_REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# API key(s), comma-separated for multiple (REQUIRED)
PAY_API_KEY=YOUR_API_KEY

# ==============================================
# 可选配置 (Optional Configuration)
# ==============================================
# Force disable WeChat Pay even if configured
# DISABLE_WECHAT_PAY=false

# Force disable Alipay Sandbox even if configured
# DISABLE_ALIPAY_SANDBOX=false
