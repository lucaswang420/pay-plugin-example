# Production Environment Configuration
# For production deployment

# ===========================================
# Pay Plugin Required Variables (CANONICAL)
# ===========================================
PAY_DB_PASSWORD=${PAY_DB_PASSWORD}
PAY_REDIS_PASSWORD=${PAY_REDIS_PASSWORD}
PAY_API_KEY=${PAY_API_KEY}

# ===========================================
# Application Configuration
# ===========================================
APP_THREADS=16
APP_ENABLE_SESSION=true
APP_SESSION_TIMEOUT=1200
APP_LOG_LEVEL=info

# ===========================================
# Server Configuration
# ===========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_ENABLE_HTTPS=true

# SSL/TLS Configuration (REQUIRED for production)
SERVER_CERT_PATH=/etc/ssl/certs/pay_server.crt
SERVER_KEY_PATH=/etc/ssl/private/pay_server.key
SERVER_CONF_PATH=/etc/ssl/openssl.cnf

# ===========================================
# WeChat Pay Configuration (Production)
# ===========================================
# IMPORTANT: Use environment variables or secret management for these values
WECHAT_APPID=${WECHAT_APPID}
WECHAT_MCHID=${WECHAT_MCHID}
WECHAT_API_V3_KEY=${WECHAT_API_V3_KEY}
WECHAT_CERT_PATH=/etc/wechat/certs/apiclient_cert.pem
WECHAT_KEY_PATH=/etc/wechat/certs/apiclient_key.pem
WECHAT_SERIAL_NO=${WECHAT_SERIAL_NO}
WECHAT_NOTIFY_URL=https://pay.yourdomain.com/api/callback
WECHAT_BASE_URL=https://api.mch.weixin.qq.com

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=${DB_HOST}
DB_PORT=5432
DB_NAME=pay_production
DB_USER=${DB_USER}
DB_CONNECTION_TIMEOUT=30
DB_MAX_CONNECTIONS=100

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_CONNECTION_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50

# ===========================================
# Idempotency Configuration
# ===========================================
IDEMPOTENCY_TTL=604800
IDEMPOTENCY_USE_REDIS=true

# ===========================================
# Monitoring Configuration
# ===========================================
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=true

# ===========================================
# Security Configuration
# ===========================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ===========================================
# Feature Flags
# ===========================================
ENABLE_REFUND=true
ENABLE_RECONCILIATION=true
ENABLE_CALLBACK=true
RECONCILIATION_CRON="0 2 * * *"

# ===========================================
# Production Settings
# ===========================================
ENABLE_HOT_RELOAD=false
VERBOSE_LOGGING=false
MOCK_WECHAT_PAY=false

# ===========================================
# Backup and Maintenance
# ===========================================
DB_BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS=30
LOG_RETENTION_DAYS=7
